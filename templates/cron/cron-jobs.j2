# Managed by the Pi Home Automation Appliance Provisioning Framework.
# Manual edits will be overwritten if this content drifts from the
# rendered template on a future run.
#
# /etc/cron.d files need an explicit user field (unlike a personal
# crontab edited via `crontab -e`) -- every line below runs as root,
# which is fine since this framework already requires root to run at all.

# Nightly reboot
00 03 * * * root /sbin/reboot

{% if healthcheck_url %}
# Health check ping (healthchecks.io) -- -fsS: fail + stay silent on
# success, but still surface a real curl error if one happens
*/5 * * * * root curl -fsS {{ healthcheck_url }} >/dev/null 2>&1
{% endif %}
